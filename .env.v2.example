# Grimnir Radio v2.0 HA environment template
#
# Copy this file to .env on each proxmox VM & fill in the real values. Two
# VMs in the same region share most of these. Per-VM values are marked
# `<NODE-SPECIFIC>`. Secrets are marked `<SECRET>`; never check this file in
# with real secrets.
#
# Source of truth for each variable's behavior is the binary's README:
#   cmd/grimnir-fanout/README.md
#   cmd/edge-encoder/README.md
#   docs/v2/UPGRADE.md
#   docs/v2/RELEASE_NOTES.md
#
# Layout: substrate, then per-binary, then deploy tool, then observability.

# =============================================================================
# Substrate
# =============================================================================

# Region identifier; drives ntfy topic naming, NetClock lease keys, audit rows.
GRIMNIR_REGION=prod-us

# Environment band; affects log level defaults & dev-only fallbacks.
GRIMNIR_ENV=production

# Postgres DSN. Postgres 16+ required. Both VMs share this.
# Use sslmode=require in prod.
GRIMNIR_DB_DSN=postgres://grimnir:<SECRET-GRIMNIR_PW>@pg.example.internal:5432/grimnir?sslmode=require

# Redis. Both VMs share this. v2 requires it for leader election + event bus
# + cross-fanout session replication.
GRIMNIR_REDIS_ADDR=redis.example.internal:6379
GRIMNIR_REDIS_PASSWORD=<SECRET-REDIS_PW>

# JWT signing secret. Same value on both VMs in a region; different across
# regions.
GRIMNIR_JWT_SIGNING_KEY=<SECRET-JWT-32B-BASE64>

# =============================================================================
# Control plane (cmd/grimnirradio)
# =============================================================================

# HTTP listener (behind the listener VIP, fronted by edge-VPS nginx).
GRIMNIR_HTTP_BIND=0.0.0.0
GRIMNIR_HTTP_PORT=8080

# Media engine gRPC; v2 keeps this loopback per-VM since each VM runs its
# own engine.
GRIMNIR_MEDIA_ENGINE_GRPC_ADDR=mediaengine:9091

# Media backend: `fs` (v1) or `s3` (v2 HA). v2 prod = `s3` against R2.
GRIMNIR_MEDIA_BACKEND=s3
GRIMNIR_MEDIA_ROOT=/var/lib/grimnir/media

# R2 / S3 configuration. `auto` region works for Cloudflare R2; path-style
# addressing on by default (R2 default).
GRIMNIR_S3_BUCKET=grimnir-media-prod-us
GRIMNIR_S3_REGION=auto
GRIMNIR_S3_ENDPOINT=https://<R2-ACCOUNT-ID>.r2.cloudflarestorage.com
GRIMNIR_S3_ACCESS_KEY=<SECRET-R2-ACCESS-KEY>
GRIMNIR_S3_SECRET_KEY=<SECRET-R2-SECRET-KEY>
GRIMNIR_S3_PATH_STYLE=true

# Leader election for the HA control plane.
GRIMNIR_LEADER_ELECTION_ENABLED=true
GRIMNIR_INSTANCE_ID=<NODE-SPECIFIC-grimnir-node-a-or-b>

# Scheduler lookahead in minutes (2880 = 48h; default is 168h).
GRIMNIR_SCHEDULER_LOOKAHEAD_MINUTES=2880

# Prometheus metrics bind (scraped from the obs host).
GRIMNIR_METRICS_BIND=0.0.0.0:9000

# =============================================================================
# Media engine (cmd/mediaengine) — HA wiring
# =============================================================================

# Emit raw L16 PCM via RTP to every fan-out / edge-encoder downstream.
GRIMNIR_HA_PCM_RTP_ENABLED=true

# Comma-separated host:port list for PCM-RTP delivery. Two-VM layout: both
# engines push to the edge-encoder on both VMs.
GRIMNIR_HA_PCM_RTP_TARGETS=<node-a-ip>:5004,<node-b-ip>:5004

# Region-wide shared clock so PCM samples from both engines align.
GRIMNIR_NETCLOCK_ENABLED=true
GRIMNIR_NETCLOCK_PORT=9094
GRIMNIR_NETCLOCK_REGION=prod-us
# Slaves dial this host:port. Conventionally node-a is master; node-b dials it.
GRIMNIR_NETCLOCK_MASTER_ADDR=<node-a-ip>:9094

# WebRTC ingest (legacy live-DJ path; fan-out also exposes its own).
GRIMNIR_WEBRTC_ENABLED=true
GRIMNIR_WEBRTC_RTP_PORT=5004

# =============================================================================
# Live-input fan-out (cmd/grimnir-fanout)
# =============================================================================

FANOUT_BIND_ADDR=0.0.0.0
FANOUT_GRPC_PORT=9093
FANOUT_HTTP_PORT=8003
FANOUT_METRICS_PORT=9193
FANOUT_HARBOR_PORT=8000
FANOUT_RTP_PORT=5006
FANOUT_SRT_PORT=1935
FANOUT_WEBRTC_HTTP_PORT=8004

# Engine A & B RTP ingress targets (the engines publish PCM here).
FANOUT_ENGINE_A_RTP=<node-a-ip>:5005
FANOUT_ENGINE_B_RTP=<node-b-ip>:5005

# Control plane gRPC for DJ auth. When empty, fan-out boots in
# AcceptAllAuthenticator mode (dev only — never run prod without this).
# CAVEAT (v2.0.0-rc.5): the control plane's DJAuth gRPC server is still
# stubbed (internal/live/djauth_grpc_stub.go); fan-out's auth path falls
# back to dev-mode behaviour until that lands. Track in a follow-up release.
FANOUT_CONTROL_PLANE_GRPC=<control-plane-host>:9090

# Redis for cross-fanout session replication.
FANOUT_REDIS_ADDR=redis.example.internal:6379

# NetClock sync — must match the media-engine NetClock config.
FANOUT_NETCLOCK_ENABLED=true
FANOUT_NETCLOCK_MASTER_ADDR=<node-a-ip>:9094

# =============================================================================
# Edge encoder (cmd/edge-encoder)
# =============================================================================

EDGE_ENCODER_BIND_ADDR=0.0.0.0
EDGE_ENCODER_GRPC_PORT=9092
EDGE_ENCODER_METRICS_PORT=9192
EDGE_ENCODER_HTTP_PORT=8001
EDGE_ENCODER_RTP_PORT_A=5004
EDGE_ENCODER_RTP_PORT_B=5005

# gRPC addresses of each engine; used for HLS metadata + state-of-input
# queries. Cross-VM.
EDGE_ENCODER_ENGINE_A_GRPC=<node-a-ip>:9091
EDGE_ENCODER_ENGINE_B_GRPC=<node-b-ip>:9091

# Output codec: mp3 or aac.
EDGE_ENCODER_OUTPUT_FORMAT=mp3
EDGE_ENCODER_OUTPUT_BITRATE_KBPS=128

# HLS segment offload to R2 (cheap CDN-style fanout).
EDGE_ENCODER_HLS_ENABLED=true
EDGE_ENCODER_HLS_S3_BUCKET=grimnir-hls-prod-us
EDGE_ENCODER_HLS_S3_REGION=auto
EDGE_ENCODER_HLS_S3_ENDPOINT=https://<R2-ACCOUNT-ID>.r2.cloudflarestorage.com
EDGE_ENCODER_HLS_S3_USE_PATH_STYLE=true
EDGE_ENCODER_HLS_SEGMENT_DIR=/var/lib/grimnir-hls

# =============================================================================
# grimnir-deploy (operator workstation only — not on the proxmox VMs)
# =============================================================================
#
# These belong on the operator's workstation, not in the per-VM .env. Listed
# here so the operator has a single canonical inventory.

# GRIMNIR_DEPLOY_DB_DSN=postgres://grimnir:<SECRET>@pg.example.internal:5432/grimnir?sslmode=require
# GRIMNIR_DEPLOY_REDIS_ADDR=redis.example.internal:6379
# GRIMNIR_DEPLOY_REDIS_PASSWORD=<SECRET-REDIS_PW>
# GRIMNIR_DEPLOY_OPERATOR=alice
# GRIMNIR_DEPLOY_PEER_HOST=<node-b-ip>
# GRIMNIR_DEPLOY_PEER_SSH_USER=<ssh-user>
# GRIMNIR_DEPLOY_PEER_SSH_PORT=22
# GRIMNIR_DEPLOY_PEER_SSH_KEY=/home/alice/.ssh/grimnir-deploy-ed25519
# GRIMNIR_DEPLOY_POLICY=strict
# GRIMNIR_DEPLOY_WINDOW_CRON=0 14-18 * * 1-4
# GRIMNIR_DEPLOY_SOAK_WINDOW=30m
# GRIMNIR_DEPLOY_ROLLBACK_WINDOW=72h
# GRIMNIR_DEPLOY_AUTOROLLBACK_ENABLED=true
# GRIMNIR_DEPLOY_AUTOROLLBACK_PROM_URL=http://prometheus.example.internal:9090
# GRIMNIR_DEPLOY_AUTOROLLBACK_TICK=15s

# =============================================================================
# Observability (alertmanager-ntfy bridge + prometheus URL)
# =============================================================================

# Loopback HTTP bind for the bridge (Alertmanager → ntfy).
GRIMNIR_ALERTBRIDGE_ADDR=127.0.0.1:9095

# ntfy server + per-tier tokens.
GRIMNIR_NTFY_URL=https://ntfy.example.com
GRIMNIR_NTFY_AUDIT_TOPIC=grimnir-audit-prod-us
GRIMNIR_NTFY_PAGE_TOPIC=grimnir-region-prod-us-page
GRIMNIR_NTFY_TOKEN_AUDIT=<SECRET-NTFY-AUDIT>
GRIMNIR_NTFY_TOKEN_PAGE=<SECRET-NTFY-PAGE>
GRIMNIR_NTFY_TOKEN_ROLLBACK=<SECRET-NTFY-ROLLBACK>

# Prometheus URL the auto-rollback observer polls.
GRIMNIR_PROMETHEUS_URL=http://prometheus.example.internal:9090

# VIPs the partition-recovery runbook checks for split-brain.
GRIMNIR_LISTENER_VIP=<listener-vip>
GRIMNIR_DJ_VIP=<dj-vip>

# =============================================================================
# Secrets backend
# =============================================================================

# `env` (default; reads this file) or `vault` (HashiCorp Vault, contract-
# tested but not production-soaked per docs/v2/RELEASE_NOTES.md).
GRIMNIR_SECRETS_BACKEND=env
GRIMNIR_SECRETS_ENV_FILE=/etc/grimnir/secrets.env
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_ROLE_ID=<SECRET>
# VAULT_SECRET_ID=<SECRET>
